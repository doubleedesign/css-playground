{
	"compilerOptions": {
		"module": "esnext",
		"target": "esnext",
		"moduleResolution": "bundler",
		"lib": [
			"ESNext",
			"DOM",
			"DOM.Iterable"
		],
		"skipLibCheck": true,
		"esModuleInterop": true,
		"isolatedModules": true,
		"resolveJsonModule": true,
		"allowJs": true,
		"allowSyntheticDefaultImports": true,
		"declaration": true,
	},
	"include": ["**/*.ts"],
	"exclude": [
		"node_modules",
		"dist",
		"tests",
		"**/*.test.ts",
		"**/*.spec.ts",
		"**/*.stories.ts",
		"vitest.setup.ts"
	]
}